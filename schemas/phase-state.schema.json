{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Firebase Security Agent Phase State",
  "description": "Standard output schema written by each phase for consumption by subsequent phases",
  "type": "object",
  "required": ["phase", "timestamp", "project_id", "status"],
  "properties": {
    "phase": {
      "type": "string",
      "description": "Phase identifier",
      "enum": ["1", "2", "3", "4", "5"]
    },
    "timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "project_id": {
      "type": "string"
    },
    "org_id": {
      "type": "string",
      "nullable": true
    },
    "status": {
      "type": "string",
      "enum": ["COMPLETE", "PARTIAL", "BLOCKED", "SKIPPED"],
      "description": "COMPLETE=all checks ran, PARTIAL=some checks skipped due to missing perms, BLOCKED=critical failure"
    },
    "duration_seconds": {
      "type": "number",
      "nullable": true
    },
    "errors": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "command": {"type": "string"},
          "error": {"type": "string"},
          "impact": {"type": "string"}
        }
      }
    },

    "findings": {
      "type": "array",
      "description": "Findings generated by this phase (phases 2-5)",
      "items": {"$ref": "finding.schema.json"}
    },

    "enabled_services": {
      "type": "array",
      "description": "Phase 1 output: all enabled services",
      "items": {"type": "string"},
      "nullable": true
    },
    "disabled_services": {
      "type": "array",
      "description": "Phase 1 output: all disabled services",
      "items": {"type": "string"},
      "nullable": true
    },

    "firebase_services": {
      "type": "array",
      "description": "Phase 1 output: enabled Firebase-specific services",
      "items": {"type": "string"},
      "nullable": true
    },
    "firebase_apps": {
      "type": "array",
      "description": "Phase 1 output: registered Firebase apps",
      "items": {
        "type": "object",
        "properties": {
          "platform": {"type": "string", "enum": ["android", "ios", "web"]},
          "app_id": {"type": "string"},
          "display_name": {"type": "string"}
        }
      },
      "nullable": true
    },
    "service_accounts": {
      "type": "array",
      "description": "Phase 1 output: service account inventory",
      "items": {
        "type": "object",
        "properties": {
          "email": {"type": "string"},
          "firebase_related": {"type": "boolean"}
        }
      },
      "nullable": true
    },
    "data_stores": {
      "type": "object",
      "description": "Phase 1 output: discovered data stores",
      "properties": {
        "firestore_databases": {"type": "array", "items": {"type": "string"}},
        "rtdb_instances": {"type": "array", "items": {"type": "string"}},
        "storage_buckets": {"type": "array", "items": {"type": "string"}}
      },
      "nullable": true
    },

    "security_rules": {
      "type": "object",
      "description": "Phase 3 output: security rules analysis",
      "properties": {
        "firestore": {
          "type": "object",
          "properties": {
            "deployed": {"type": "boolean"},
            "rules_content": {"type": "string", "nullable": true},
            "assessment": {"type": "string", "nullable": true}
          }
        },
        "rtdb": {
          "type": "object",
          "properties": {
            "deployed": {"type": "boolean"},
            "rules_content": {"type": "string", "nullable": true},
            "assessment": {"type": "string", "nullable": true}
          }
        },
        "storage": {
          "type": "object",
          "properties": {
            "deployed": {"type": "boolean"},
            "rules_content": {"type": "string", "nullable": true},
            "assessment": {"type": "string", "nullable": true}
          }
        }
      },
      "nullable": true
    },

    "risk_summary": {
      "type": "object",
      "description": "Phase 5 output",
      "properties": {
        "project_score": {"type": "number"},
        "score_band": {"type": "string"},
        "critical_count": {"type": "integer"},
        "high_count": {"type": "integer"},
        "medium_count": {"type": "integer"},
        "low_count": {"type": "integer"},
        "total_findings": {"type": "integer"},
        "top_remediation_ids": {"type": "array", "items": {"type": "string"}}
      },
      "nullable": true
    },

    "scan_integrity": {
      "type": "object",
      "description": "Scan integrity metadata",
      "properties": {
        "claude_md_sha256": {"type": "string"},
        "scan_start": {"type": "string", "format": "date-time"},
        "reviewer": {"type": "string"},
        "review_timestamp": {"type": "string", "format": "date-time"},
        "output_file_count": {"type": "integer"}
      },
      "nullable": true
    }
  }
}
