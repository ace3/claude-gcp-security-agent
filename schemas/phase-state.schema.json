{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "GCP Security Agent Phase State",
  "description": "Standard output schema written by each phase for consumption by subsequent phases",
  "type": "object",
  "required": ["phase", "timestamp", "project_id", "status"],
  "properties": {
    "phase": {
      "type": "string",
      "description": "Phase identifier",
      "examples": ["0", "0.5", "1", "2", "3", "4a", "4b", "4c", "4d", "4e", "4f", "5", "6", "7"]
    },
    "timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "project_id": {
      "type": "string"
    },
    "org_id": {
      "type": "string",
      "nullable": true
    },
    "status": {
      "type": "string",
      "enum": ["COMPLETE", "PARTIAL", "BLOCKED", "SKIPPED", "READY"],
      "description": "COMPLETE=all checks ran, PARTIAL=some checks skipped due to missing perms, BLOCKED=critical failure"
    },
    "duration_seconds": {
      "type": "number",
      "nullable": true
    },
    "errors": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "command": {"type": "string"},
          "error": {"type": "string"},
          "impact": {"type": "string"}
        }
      }
    },

    "findings": {
      "type": "array",
      "description": "Findings generated by this phase (phases 0, 0.5, 4a-4f, 5)",
      "items": {"$ref": "finding.schema.json"}
    },

    "enabled_services": {
      "type": "array",
      "description": "Phase 1 output",
      "items": {"type": "string"},
      "nullable": true
    },
    "disabled_services": {
      "type": "array",
      "items": {"type": "string"},
      "nullable": true
    },

    "roles_requested": {
      "type": "array",
      "description": "Phase 2 output",
      "items": {"type": "string"},
      "nullable": true
    },
    "roles_per_service": {
      "type": "object",
      "description": "Phase 2 output: map of service → [roles]",
      "nullable": true
    },
    "sa_email": {
      "type": "string",
      "nullable": true
    },

    "permission_tests": {
      "type": "array",
      "description": "Phase 3 output",
      "items": {
        "type": "object",
        "properties": {
          "test": {"type": "string"},
          "role": {"type": "string"},
          "status": {"type": "string", "enum": ["PASS", "FAIL"]}
        }
      },
      "nullable": true
    },

    "attack_paths": {
      "type": "array",
      "description": "Phase 0.5 output",
      "items": {
        "type": "object",
        "properties": {
          "id": {"type": "string"},
          "persona": {"type": "string"},
          "viable": {"type": "boolean"},
          "entry_point": {"type": "string"},
          "path": {"type": "array", "items": {"type": "string"}},
          "crown_jewel": {"type": "string"},
          "blocking_controls": {"type": "array", "items": {"type": "string"}}
        }
      },
      "nullable": true
    },
    "crown_jewels": {
      "type": "array",
      "description": "Phase 0.5: highest value resources",
      "items": {
        "type": "object",
        "properties": {
          "resource_type": {"type": "string"},
          "resource_name": {"type": "string"},
          "sensitivity": {"type": "string", "enum": ["CRITICAL", "HIGH", "MEDIUM"]},
          "reason": {"type": "string"}
        }
      },
      "nullable": true
    },

    "risk_summary": {
      "type": "object",
      "description": "Phase 5 output",
      "properties": {
        "project_score": {"type": "number"},
        "score_band": {"type": "string"},
        "critical_count": {"type": "integer"},
        "high_count": {"type": "integer"},
        "medium_count": {"type": "integer"},
        "low_count": {"type": "integer"},
        "total_findings": {"type": "integer"},
        "cis_l1_coverage_pct": {"type": "number"},
        "cis_l2_coverage_pct": {"type": "number"},
        "top_10_finding_ids": {"type": "array", "items": {"type": "string"}}
      },
      "nullable": true
    },

    "scan_integrity": {
      "type": "object",
      "description": "Phase 7 output",
      "properties": {
        "claude_md_sha256": {"type": "string"},
        "manifest_file": {"type": "string"},
        "reviewer": {"type": "string"},
        "review_timestamp": {"type": "string", "format": "date-time"},
        "output_file_count": {"type": "integer"}
      },
      "nullable": true
    }
  }
}
