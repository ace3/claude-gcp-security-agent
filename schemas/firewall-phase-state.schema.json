{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Firewall Security Agent Phase State",
  "description": "Standard output schema written by each phase for consumption by subsequent phases",
  "type": "object",
  "required": ["phase", "timestamp", "project_id", "status"],
  "properties": {
    "phase": {
      "type": "string",
      "description": "Phase identifier",
      "enum": ["1", "2", "3", "4", "5"]
    },
    "timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "project_id": {
      "type": "string"
    },
    "org_id": {
      "type": "string",
      "nullable": true
    },
    "folder_id": {
      "type": "string",
      "nullable": true
    },
    "status": {
      "type": "string",
      "enum": ["COMPLETE", "PARTIAL", "BLOCKED", "SKIPPED"],
      "description": "COMPLETE=all checks ran, PARTIAL=some checks skipped due to missing perms, BLOCKED=critical failure"
    },
    "duration_seconds": {
      "type": "number",
      "nullable": true
    },
    "errors": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "command": {"type": "string"},
          "error": {"type": "string"},
          "impact": {"type": "string"}
        }
      }
    },

    "findings": {
      "type": "array",
      "description": "Findings generated by this phase (phases 2-5)",
      "items": {"$ref": "firewall-finding.schema.json"}
    },

    "networks": {
      "type": "array",
      "description": "Phase 1 output: VPC networks",
      "items": {
        "type": "object",
        "properties": {
          "name": {"type": "string"},
          "mode": {"type": "string", "enum": ["auto", "custom", "legacy"]},
          "is_default": {"type": "boolean"},
          "peerings": {"type": "array", "items": {"type": "string"}}
        }
      },
      "nullable": true
    },
    "subnets": {
      "type": "array",
      "description": "Phase 1 output: subnets",
      "items": {
        "type": "object",
        "properties": {
          "name": {"type": "string"},
          "region": {"type": "string"},
          "network": {"type": "string"},
          "ip_range": {"type": "string"},
          "private_google_access": {"type": "boolean"},
          "flow_logs": {"type": "boolean"}
        }
      },
      "nullable": true
    },
    "instances": {
      "type": "array",
      "description": "Phase 1 output: Compute Engine instances",
      "items": {
        "type": "object",
        "properties": {
          "name": {"type": "string"},
          "zone": {"type": "string"},
          "status": {"type": "string"},
          "tags": {"type": "array", "items": {"type": "string"}},
          "service_accounts": {"type": "array", "items": {"type": "string"}},
          "network_interfaces": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "network": {"type": "string"},
                "subnet": {"type": "string"},
                "internal_ip": {"type": "string"},
                "external_ip": {"type": "string", "nullable": true}
              }
            }
          }
        }
      },
      "nullable": true
    },
    "instance_groups": {
      "type": "array",
      "description": "Phase 1 output: instance groups",
      "items": {
        "type": "object",
        "properties": {
          "name": {"type": "string"},
          "type": {"type": "string", "enum": ["managed", "unmanaged"]},
          "zone": {"type": "string"},
          "size": {"type": "integer"}
        }
      },
      "nullable": true
    },
    "firewall_summary": {
      "type": "object",
      "description": "Phase 1 output: firewall rule counts",
      "properties": {
        "total_rules": {"type": "integer"},
        "ingress_rules": {"type": "integer"},
        "egress_rules": {"type": "integer"},
        "default_rules": {"type": "integer"},
        "custom_rules": {"type": "integer"},
        "disabled_rules": {"type": "integer"}
      },
      "nullable": true
    },
    "firewall_policies": {
      "type": "object",
      "description": "Phase 1 output: discovered firewall policies",
      "properties": {
        "network_policies": {"type": "array", "items": {"type": "string"}},
        "hierarchical_policies": {"type": "array", "items": {"type": "string"}}
      },
      "nullable": true
    },
    "network_tags": {
      "type": "object",
      "description": "Phase 1 output: network tag inventory",
      "properties": {
        "on_instances": {"type": "array", "items": {"type": "string"}},
        "in_firewall_rules": {"type": "array", "items": {"type": "string"}},
        "in_source_tags": {"type": "array", "items": {"type": "string"}}
      },
      "nullable": true
    },

    "vpc_rules": {
      "type": "array",
      "description": "Phase 2 output: VPC firewall rule assessments",
      "items": {
        "type": "object",
        "properties": {
          "rule_name": {"type": "string"},
          "network": {"type": "string"},
          "direction": {"type": "string"},
          "action": {"type": "string"},
          "priority": {"type": "integer"},
          "source_ranges": {"type": "array", "items": {"type": "string"}},
          "allowed": {"type": "array"},
          "target_tags": {"type": "array", "items": {"type": "string"}},
          "disabled": {"type": "boolean"},
          "assessment": {"type": "string"},
          "finding_ids": {"type": "array", "items": {"type": "string"}}
        }
      },
      "nullable": true
    },

    "policy_rules": {
      "type": "object",
      "description": "Phase 3 output: firewall policy rule assessments",
      "properties": {
        "hierarchical": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "policy_name": {"type": "string"},
              "level": {"type": "string", "enum": ["organization", "folder"]},
              "rules": {"type": "array"},
              "assessment": {"type": "string"},
              "finding_ids": {"type": "array", "items": {"type": "string"}}
            }
          }
        },
        "network": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "policy_name": {"type": "string"},
              "associated_networks": {"type": "array", "items": {"type": "string"}},
              "rules": {"type": "array"},
              "assessment": {"type": "string"},
              "finding_ids": {"type": "array", "items": {"type": "string"}}
            }
          }
        }
      },
      "nullable": true
    },

    "effective_firewalls": {
      "type": "array",
      "description": "Phase 4 output: per-instance effective firewall analysis",
      "items": {
        "type": "object",
        "properties": {
          "instance_name": {"type": "string"},
          "zone": {"type": "string"},
          "external_ip": {"type": "string", "nullable": true},
          "exposed_ports": {"type": "array", "items": {"type": "string"}},
          "permissive_rules": {"type": "array", "items": {"type": "string"}},
          "finding_ids": {"type": "array", "items": {"type": "string"}}
        }
      },
      "nullable": true
    },
    "diagrams_generated": {
      "type": "array",
      "description": "Phase 4 output: list of diagram files generated",
      "items": {"type": "string"},
      "nullable": true
    },

    "risk_summary": {
      "type": "object",
      "description": "Phase 5 output",
      "properties": {
        "project_score": {"type": "number"},
        "score_band": {"type": "string"},
        "critical_count": {"type": "integer"},
        "high_count": {"type": "integer"},
        "medium_count": {"type": "integer"},
        "low_count": {"type": "integer"},
        "total_findings": {"type": "integer"},
        "top_remediation_ids": {"type": "array", "items": {"type": "string"}}
      },
      "nullable": true
    },

    "scan_integrity": {
      "type": "object",
      "description": "Scan integrity metadata",
      "properties": {
        "claude_firewall_md_sha256": {"type": "string"},
        "scan_start": {"type": "string", "format": "date-time"},
        "reviewer": {"type": "string"},
        "review_timestamp": {"type": "string", "format": "date-time"},
        "output_file_count": {"type": "integer"}
      },
      "nullable": true
    },

    "summary": {
      "type": "object",
      "description": "Phase 1 output: high-level counts",
      "properties": {
        "network_count": {"type": "integer"},
        "subnet_count": {"type": "integer"},
        "instance_count": {"type": "integer"},
        "instances_with_external_ip": {"type": "integer"},
        "total_firewall_rules": {"type": "integer"},
        "total_network_tags": {"type": "integer"}
      },
      "nullable": true
    }
  }
}
