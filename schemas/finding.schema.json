{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "GCP Security Finding",
  "description": "Standard schema for all findings produced by the GCP Security Excellence Agent",
  "type": "object",
  "required": [
    "id",
    "internal_id",
    "phase",
    "severity",
    "title",
    "resource_type",
    "resource_name",
    "finding",
    "why_it_matters",
    "remediation_command",
    "nist_function",
    "cis_control",
    "score",
    "threat_model_amplified",
    "timestamp"
  ],
  "properties": {
    "id": {
      "type": "string",
      "description": "Unique finding UUID for this scan",
      "example": "f1a2b3c4-d5e6-7890-abcd-ef1234567890"
    },
    "internal_id": {
      "type": "string",
      "description": "Stable control ID format: GCP-[CATEGORY]-[NUMBER]",
      "pattern": "^GCP-[A-Z]+-[0-9]+$",
      "examples": [
        "GCP-IAM-01",
        "GCP-NET-03",
        "GCP-STOR-02",
        "GCP-BUILD-01",
        "GCP-RUN-02",
        "GCP-KMS-01",
        "GCP-LOG-01"
      ]
    },
    "phase": {
      "type": "string",
      "enum": ["0", "0.5", "1", "2", "3", "4a", "4b", "4c", "4d", "4e", "4f", "5"],
      "description": "Phase that generated this finding"
    },
    "severity": {
      "type": "string",
      "enum": ["CRITICAL", "HIGH", "MEDIUM", "LOW"],
      "description": "Base severity before threat model amplification"
    },
    "score": {
      "type": "number",
      "description": "Numeric score after threat model multiplier applied",
      "minimum": 0,
      "maximum": 15
    },
    "threat_model_amplified": {
      "type": "boolean",
      "description": "True if this finding sits on a viable attack path from Phase 0.5"
    },
    "attack_path_reference": {
      "type": "string",
      "description": "Reference to attack path from phase-0.5-state.json (if amplified)",
      "nullable": true
    },
    "title": {
      "type": "string",
      "description": "Short human-readable title",
      "example": "Cloud Build SA has roles/editor"
    },
    "finding": {
      "type": "string",
      "description": "Detailed description of what was found"
    },
    "why_it_matters": {
      "type": "string",
      "description": "Plain-language explanation of the risk"
    },
    "resource_type": {
      "type": "string",
      "enum": [
        "service_account",
        "iam_binding",
        "iam",
        "compute_instance",
        "firewall_rule",
        "network",
        "subnet",
        "disk",
        "gcs_bucket",
        "bigquery",
        "bigquery_dataset",
        "datastore",
        "firestore",
        "cloud_run_service",
        "artifact_registry_repo",
        "cloud_build_trigger",
        "cloud_sql_instance",
        "secret",
        "kms_key",
        "kms_keyring",
        "org_policy",
        "log_sink",
        "alert_policy",
        "scc_finding",
        "workload_identity_pool",
        "vpc_connector",
        "project",
        "organization"
      ]
    },
    "resource_name": {
      "type": "string",
      "description": "Full resource identifier (e.g. projects/my-project/serviceAccounts/sa@...)"
    },
    "remediation_command": {
      "type": "string",
      "description": "Exact gcloud command to fix this finding (with $PROJECT_ID placeholder)"
    },
    "remediation_effort": {
      "type": "string",
      "enum": ["< 5 minutes", "< 30 minutes", "< 2 hours", "< 1 day", "> 1 day"],
      "description": "Estimated effort to remediate"
    },
    "rollback_command": {
      "type": "string",
      "description": "Command to revert the fix if needed",
      "nullable": true
    },
    "nist_function": {
      "type": "string",
      "enum": ["GV", "ID", "PR", "DE", "RS", "RC"],
      "description": "NIST CSF 2.0 function: GV=Govern, ID=Identify, PR=Protect, DE=Detect, RS=Respond, RC=Recover"
    },
    "nist_category": {
      "type": "string",
      "description": "NIST CSF category code",
      "example": "PR.AC-1",
      "nullable": true
    },
    "cis_control": {
      "type": "string",
      "description": "CIS GCP Benchmark v2.x control ID or N/A",
      "example": "1.5"
    },
    "cis_level": {
      "type": "string",
      "enum": ["L1", "L2", "N/A"],
      "description": "CIS benchmark level"
    },
    "false_positive_risk": {
      "type": "string",
      "enum": ["LOW", "MEDIUM", "HIGH"],
      "description": "How likely this finding could be a false positive for intentional config"
    },
    "timestamp": {
      "type": "string",
      "format": "date-time",
      "description": "ISO8601 timestamp when finding was generated"
    }
  }
}
