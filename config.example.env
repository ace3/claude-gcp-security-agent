# Copy this file to config.local.env and fill in your values.
# config.local.env is gitignored -- your real project IDs never leave your machine.
#
# This agent runs as the currently authenticated gcloud user.
# No scanner service account is needed.

PROJECT_ID="YOUR_PROJECT_ID"
ORG_ID=""                    # leave blank if no org
REVIEWER_NAME=""             # human reviewer name for audit trail
